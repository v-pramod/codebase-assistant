# Optional local backend overrides.
# The backend runs without this file because all current settings have defaults.

# Backend data locations
CODEBASE_ASSISTANT_DATA_DIR=../data/backend
CODEBASE_ASSISTANT_SQLITE_PATH=../data/backend/app.sqlite3
CODEBASE_ASSISTANT_CHROMA_DIR=../data/backend/chroma
CODEBASE_ASSISTANT_CLONES_DIR=../data/backend/clones

# Infrastructure
CODEBASE_ASSISTANT_REDIS_URL=redis://localhost:6379/0

# Ingestion and parsing limits
CODEBASE_ASSISTANT_MAX_FILE_BYTES=250000
CODEBASE_ASSISTANT_MAX_REPO_BYTES=200000000
CODEBASE_ASSISTANT_MAX_INDEXED_FILES=20000
CODEBASE_ASSISTANT_CHUNK_MAX_LINES=80
CODEBASE_ASSISTANT_CHUNK_OVERLAP_LINES=10
CODEBASE_ASSISTANT_PARSER_VERSION=plain-symbol-v1

# Provider settings for retrieval/chat once live provider wiring is enabled.
# Keep this backend-only. Never expose it to the frontend.
CODEBASE_ASSISTANT_OPENROUTER_API_KEY=
CODEBASE_ASSISTANT_OPENROUTER_CHAT_MODEL=deepseek/deepseek-chat
CODEBASE_ASSISTANT_OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
